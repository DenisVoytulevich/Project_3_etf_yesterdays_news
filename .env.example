# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Google Sheets
GOOGLE_SHEETS_ID=your_spreadsheet_id
GOOGLE_CREDENTIALS_PATH=credentials/google_service_account.json

# OpenAI
OPENAI_API_KEY=your_openai_key
# GPT-5: gpt-5-nano (самая дешёвая) | gpt-5-mini | gpt-5
OPENAI_MODEL=gpt-5-nano

# NewsAPI (для обязательного скрининга по отраслям)
NEWSAPI_KEY=

# Расписание брифинга
TIMEZONE=Europe/Warsaw
DAILY_BRIEFING_HOUR=9
DAILY_BRIEFING_MINUTE=0

# Пути в контейнере (интеграция с Project_3_bot: код ro, данные — volume)
# DAILY_BRIEFING_ROOT=/app/briefing
# DAILY_BRIEFING_DATA_DIR=/app/data

# Внеурочное время: ручной /report и кнопка (будни с этого часа + выходные)
OFF_HOURS_WEEKDAY_START=19
OFF_HOURS_WEEKDAY_END=9
